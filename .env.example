# ─── Database (Neon Local — Docker) ──────────────────────────────────────────
# Required. Pre-filled for local Docker via npm run neon-local:up.
#
# !! IMPORTANT: Never put Neon cloud connection strings in .env.local !!
# Local dev always uses Docker (neon-local). Vercel injects DATABASE_URL and
# DIRECT_URL for Preview and Production environments automatically via the
# Neon Vercel Integration — do not set those in Vercel env vars manually.
DATABASE_URL="postgres://neon:npg@localhost:5432/neondb?sslmode=require"
DIRECT_URL="postgres://neon:npg@localhost:5432/neondb?sslmode=require"
SHADOW_DATABASE_URL="postgres://neon:npg@localhost:5432/neondb_shadow?sslmode=require"

# Required for Neon Local Docker container (not needed if using cloud Neon directly)
NEON_API_KEY=""
NEON_PROJECT_ID=""
NEON_BRANCH_ID=""

# ─── App URL ──────────────────────────────────────────────────────────────────
# Required. Used for Polar checkout return URLs and webhook registration.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─── Authentication (Clerk) ───────────────────────────────────────────────────
# Required. Get keys from https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
CLERK_SECRET_KEY=""
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_SIGN_IN_FORCE_REDIRECT_URL="/dashboard"
NEXT_PUBLIC_CLERK_SIGN_UP_FORCE_REDIRECT_URL="/dashboard"

# ─── Billing (Polar) ──────────────────────────────────────────────────────────
# Required for billing features. See docs/polar-sandbox-setup.md for local setup.
POLAR_ACCESS_TOKEN=""
POLAR_PRODUCT_ID_PRO=""
POLAR_PRODUCT_ID_LIFETIME=""
POLAR_WEBHOOK_SECRET=""
POLAR_ENVIRONMENT="sandbox"

# ─── Resume Uploads (Vercel Blob) ─────────────────────────────────────────────
# Required for resume upload feature. Get token from Vercel dashboard → Storage.
BLOB_READ_WRITE_TOKEN=""

# ─── Analytics (PostHog) ──────────────────────────────────────────────────────
# Optional. Events are silently skipped when absent.
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"
